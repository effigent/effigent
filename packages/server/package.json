    "@ccopt/core": "0.1.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
